{
  "monitoring": {
    "watch_interval": 0.5,
    "entropy_threshold": 7.2,
    "rename_rate_threshold": 5,
    "write_rate_threshold": 20,
    "encryption_detection_window": 3,
    "min_file_size_bytes": 512
  },
  "ml": {
    "model_path": "ml/models/anomaly_model.pkl",
    "retrain_interval": 3600,
    "contamination": 0.01,
    "enabled": true
  },
  "backup": {
    "max_versions": 5,
    "snapshot_interval": 300,
    "auto_snapshot": true,
    "compressed": true
  },
  "honeypot": {
    "num_canaries": 10,
    "canary_extensions": [
      ".docx",
      ".xlsx",
      ".pdf",
      ".jpg",
      ".txt"
    ],
    "alert_on_access": true,
    "alert_on_modify": true
  },
  "response": {
    "auto_kill_process": true,
    "auto_isolate_network": false,
    "auto_restore": true,
    "quarantine_path": "quarantine/"
  },
  "alerts": {
    "email_enabled": false,
    "email_to": "",
    "email_from": "",
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "telegram_enabled": false,
    "telegram_token": "",
    "telegram_chat_id": "",
    "desktop_notifications": true
  },
